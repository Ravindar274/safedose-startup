# .env  (copy this to .env and fill in your values — never commit .env to git)

# Server
PORT=5002

# MongoDB — same Atlas cluster as your Next.js app
MONGODB_URI=
# JWT — must be the SAME secret as your Next.js app so tokens are compatible
JWT_SECRET=

# Gemini
GEMINI_API_KEY=


# GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-2.0-flash

# CORS — your Next.js web app origin
CLIENT_ORIGIN=http://localhost:3000
