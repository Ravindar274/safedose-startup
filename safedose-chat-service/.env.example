# .env  (copy this to .env and fill in your values — never commit .env to git)

# Server
PORT=5002

# MongoDB — same Atlas cluster as your Next.js app
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/safedose?retryWrites=true&w=majority

# JWT — must be the SAME secret as your Next.js app so tokens are compatible
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# CORS — your Next.js web app origin
CLIENT_ORIGIN=http://localhost:3000
